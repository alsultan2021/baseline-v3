@model Baseline.Search.Components.SearchResultsViewModel

<style>
    .google-results {
        max-width: 652px;
        font-family: arial, sans-serif;
    }

    .google-result {
        margin-bottom: 28px;
    }

    .google-result-url {
        font-size: 14px;
        line-height: 1.3;
        color: #202124;
        margin-bottom: 4px;
    }

    .google-result-url a {
        color: #202124;
        text-decoration: none;
    }

    .google-result-url .domain {
        color: #202124;
    }

    .google-result-url .path {
        color: #5f6368;
        font-size: 12px;
    }

    .google-result-title {
        margin: 0 0 3px;
    }

    .google-result-title a {
        font-size: 20px;
        line-height: 1.3;
        color: #1a0dab;
        text-decoration: none;
        font-weight: 400;
    }

    .google-result-title a:hover {
        text-decoration: underline;
    }

    .google-result-title a:visited {
        color: #681da8;
    }

    .google-result-excerpt {
        font-size: 14px;
        line-height: 1.58;
        color: #4d5156;
        margin: 0;
        word-wrap: break-word;
    }

    .google-result-excerpt em,
    .google-result-excerpt strong {
        font-weight: 700;
        color: #5f6368;
    }

    .google-stats {
        font-size: 14px;
        color: #70757a;
        margin-bottom: 20px;
    }

    .google-no-results {
        font-size: 14px;
        color: #70757a;
    }

    .google-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 40px;
        gap: 8px;
    }

    .google-pagination a,
    .google-pagination span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 40px;
        height: 40px;
        font-size: 14px;
        color: #1a0dab;
        text-decoration: none;
        border-radius: 50%;
    }

    .google-pagination a:hover {
        background: #f1f3f4;
    }

    .google-pagination .active {
        background: #e8f0fe;
        color: #1a73e8;
        font-weight: 700;
        pointer-events: none;
    }

    .google-pagination .disabled {
        color: #70757a;
        pointer-events: none;
    }
</style>

<div class="google-results">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning mb-4" role="alert">
            @Model.ErrorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Query))
    {
        @if (Model.TotalCount > 0)
        {
            <p class="google-stats">About @Model.TotalCount result@(Model.TotalCount != 1 ? "s" : "")</p>
        }
        else
        {
            <div class="google-no-results">
                <p>Your search - <strong>@Model.Query</strong> - did not match any documents.</p>
            </div>
        }
    }

    @if (Model.Results.Count > 0)
    {
        @foreach (var result in Model.Results)
        {
            var uri = new Uri(result.Url, UriKind.RelativeOrAbsolute);
            var host = uri.IsAbsoluteUri ? uri.Host : "localhost";
            var path = uri.IsAbsoluteUri ? uri.AbsolutePath.Trim('/') : result.Url.Trim('/');
            <div class="google-result">
                <div class="google-result-url">
                    <a href="@result.Url">
                        <span class="domain">@host</span>
                        <span class="path"> › @path.Replace("/", " › ")</span>
                    </a>
                </div>
                <h3 class="google-result-title">
                    <a href="@result.Url">@result.Title</a>
                </h3>
                @if (!string.IsNullOrEmpty(result.Excerpt))
                {
                    <p class="google-result-excerpt">@Html.Raw(result.Excerpt)</p>
                }
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav class="google-pagination" aria-label="Search results pagination">
                @if (Model.HasPreviousPage)
                {
                    <a href="?q=@Uri.EscapeDataString(Model.Query ?? "")&page=@(Model.CurrentPage - 1)" aria-label="Previous">
                        <span>&lt;</span>
                    </a>
                }
                else
                {
                    <span class="disabled">&lt;</span>
                }

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    var isActive = i == Model.CurrentPage;
                    if (isActive)
                    {
                        <span class="active" aria-current="page">@i</span>
                    }
                    else
                    {
                        <a href="?q=@Uri.EscapeDataString(Model.Query ?? "")&page=@i">@i</a>
                    }
                }

                @if (Model.HasNextPage)
                {
                    <a href="?q=@Uri.EscapeDataString(Model.Query ?? "")&page=@(Model.CurrentPage + 1)" aria-label="Next">
                        <span>&gt;</span>
                    </a>
                }
                else
                {
                    <span class="disabled">&gt;</span>
                }
            </nav>
        }
    }
</div>