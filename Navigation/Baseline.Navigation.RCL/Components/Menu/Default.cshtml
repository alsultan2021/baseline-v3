@model Baseline.Navigation.Components.MenuViewModel

@if (Model.HasItems)
{
    <nav class="baseline-menu" aria-label="@(Model.Menu?.DisplayName ?? "Navigation")">
        <ul class="nav-list">
            @foreach (var item in Model.Menu!.Items)
            {
                <partial name="_MenuItem"
                         model="@(new Baseline.Navigation.Components.MenuItemRenderModel(item, Model.MaxDepth, 0))" />
            }
        </ul>
    </nav>
}