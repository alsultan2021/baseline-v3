<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Baseline.TabbedPages</RootNamespace>
        <AssemblyName>Baseline.TabbedPages</AssemblyName>
        <Description>Baseline v3 TabbedPages module - tabbed content pages for Xperience by Kentico</Description>
        <Authors>XperienceCommunity</Authors>
        <PackageTags>Kentico;Xperience;Baseline;TabbedPages;Tabs;Navigation</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Kentico.Xperience.Core" Version="31.2.0" />
        <PackageReference Include="Kentico.Xperience.WebApp" Version="31.2.0" />
        <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.3" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Core\Baseline.Core\Baseline.Core.csproj" />
        <ProjectReference Include="..\..\Navigation\Baseline.Navigation\Baseline.Navigation.csproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Update="Microsoft.SemanticKernel.Core" Version="1.73.0" />
    </ItemGroup>

</Project>
