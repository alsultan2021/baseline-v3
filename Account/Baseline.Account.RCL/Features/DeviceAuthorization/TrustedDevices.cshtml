@model Baseline.Account.RCL.Features.DeviceAuthorization.TrustedDevicesViewModel
@{
    ViewData["Title"] = "Trusted Devices";
}

<div class="trusted-devices-container" style="max-width: 700px; margin: 60px auto; padding: 0 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h1 style="margin-bottom: 5px;">Trusted Devices</h1>
            <p style="color: #666; font-size: 14px; margin: 0;">
                These devices can sign in without two-factor authentication.
            </p>
        </div>
        @if (Model.Devices.Count > 1)
        {
            <form method="post" action="/@Baseline.Account.RCL.Features.DeviceAuthorization.DeviceAuthorizationController.RevokeAllDevicesUrl"
                  onsubmit="return confirm('Revoke all trusted devices? You will need to verify again on each device.');">
                @Html.AntiForgeryToken()
                <button type="submit" style="padding: 8px 16px; background: #ef4444; color: white; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: 600;">
                    Revoke All
                </button>
            </form>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 12px 15px; margin-bottom: 20px; color: #166534; font-size: 14px;">
            @Model.Message
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 15px; margin-bottom: 20px; color: #dc2626; font-size: 14px;">
            @Model.Error
        </div>
    }

    @if (Model.Devices.Count == 0)
    {
        <div style="text-align: center; padding: 40px; background: #f9fafb; border-radius: 12px; color: #666;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" style="margin-bottom: 10px;">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
            <p>No trusted devices yet.</p>
            <p style="font-size: 13px;">When you check "Remember this device" during sign-in, it will appear here.</p>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 12px;">
            @foreach (var device in Model.Devices)
            {
                <div style="background: #fff; border: 1px solid @(device.IsCurrentDevice ? "#22c55e" : "#e5e7eb"); border-radius: 12px; padding: 20px; display: flex; align-items: center; gap: 15px;">
                    <!-- Device Icon -->
                    <div style="flex-shrink: 0;">
                        @if (device.DeviceType == "Mobile")
                        {
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5">
                                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
                                <line x1="12" y1="18" x2="12.01" y2="18"></line>
                            </svg>
                        }
                        else if (device.DeviceType == "Tablet")
                        {
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5">
                                <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
                                <line x1="12" y1="18" x2="12.01" y2="18"></line>
                            </svg>
                        }
                        else
                        {
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                                <line x1="8" y1="21" x2="16" y2="21"></line>
                                <line x1="12" y1="17" x2="12" y2="21"></line>
                            </svg>
                        }
                    </div>

                    <!-- Device Info -->
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-weight: 600; color: #333; display: flex; align-items: center; gap: 8px;">
                            @device.DeviceName
                            @if (device.IsCurrentDevice)
                            {
                                <span style="font-size: 11px; background: #dcfce7; color: #166534; padding: 2px 8px; border-radius: 10px; font-weight: 500;">This device</span>
                            }
                        </div>
                        <div style="font-size: 13px; color: #888; margin-top: 3px;">
                            @if (!string.IsNullOrEmpty(device.IpAddress))
                            {
                                <span>@device.IpAddress</span>
                                <span style="margin: 0 5px;">·</span>
                            }
                            <span>Trusted @device.TrustedAt.ToString("MMM d, yyyy")</span>
                            <span style="margin: 0 5px;">·</span>
                            <span>Last used @FormatRelativeTime(device.LastUsedAt)</span>
                        </div>
                    </div>

                    <!-- Revoke Button -->
                    <div style="flex-shrink: 0;">
                        <form method="post" action="/@Baseline.Account.RCL.Features.DeviceAuthorization.DeviceAuthorizationController.RevokeDeviceUrl"
                              onsubmit="return confirm('Remove this trusted device?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="trustedDeviceId" value="@device.TrustedDeviceID" />
                            <button type="submit" style="padding: 6px 14px; background: transparent; color: #ef4444; border: 1px solid #ef4444; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: 500;">
                                Remove
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utcTime.ToString("MMM d, yyyy");
    }
}
