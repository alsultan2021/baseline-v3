@model Baseline.Account.RCL.Features.ResetPassword.ResetPasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="reset-password-container">
    <h1>Change Password</h1>
    
    @if (Model?.Succeeded == true)
    {
        <div class="alert alert-success">
            <p>Your password has been changed successfully.</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model?.Error))
        {
            <div class="alert alert-danger">
                <p>@Model.Error</p>
            </div>
        }
        
        <form method="post" asp-controller="ResetPassword" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label asp-for="CurrentPassword">Current Password</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" required />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Password">New Password</label>
                <input asp-for="Password" type="password" class="form-control" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="PasswordConfirm">Confirm New Password</label>
                <input asp-for="PasswordConfirm" type="password" class="form-control" required />
                <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-primary">Change Password</button>
        </form>
    }
    
    <p class="mt-3">
        <a href="/Account/MyAccount">Back to My Account</a>
    </p>
</div>
