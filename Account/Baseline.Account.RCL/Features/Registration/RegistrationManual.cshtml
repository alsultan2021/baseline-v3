@model Baseline.Account.RCL.Features.Registration.RegistrationViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="registration-container">
    <h1>Create an Account</h1>

    @if (Model?.RegistrationSuccessful == true)
    {
        <div class="alert alert-success">
            <p>Registration successful! Please check your email to confirm your account.</p>
            <a href="/Account/LogIn" class="btn btn-primary">Go to Login</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model?.RegistrationFailureMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.RegistrationFailureMessage</p>
            </div>
        }

        <form method="post" asp-controller="Registration" asp-action="Registration">
            @Html.AntiForgeryToken()

            <div class="form-row">
                <div class="form-group col-md-6">
                    <label asp-for="User.FirstName">First Name</label>
                    <input asp-for="User.FirstName" type="text" class="form-control" required />
                    <span asp-validation-for="User.FirstName" class="text-danger"></span>
                </div>

                <div class="form-group col-md-6">
                    <label asp-for="User.LastName">Last Name</label>
                    <input asp-for="User.LastName" type="text" class="form-control" required />
                    <span asp-validation-for="User.LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="User.UserName">Username</label>
                <input asp-for="User.UserName" type="text" class="form-control" required />
                <span asp-validation-for="User.UserName" class="text-danger"></span>
                <small class="form-text text-muted">Only letters, numbers, and underscores allowed.</small>
            </div>

            <div class="form-group">
                <label asp-for="User.Email">Email Address</label>
                <input asp-for="User.Email" type="email" class="form-control" required />
                <span asp-validation-for="User.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" class="form-control" required />
                <span asp-validation-for="Password" class="text-danger"></span>
                <small class="form-text text-muted">
                    At least 8 characters with uppercase, lowercase, and numbers.
                </small>
            </div>

            <div class="form-group">
                <label asp-for="PasswordConfirm">Confirm Password</label>
                <input asp-for="PasswordConfirm" type="password" class="form-control" required />
                <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
            </div>

            <div class="form-check">
                <input asp-for="AgreeToTerms" type="checkbox" class="form-check-input" required />
                <label asp-for="AgreeToTerms" class="form-check-label">
                    I agree to the <a href="/terms" target="_blank" rel="noopener noreferrer">Terms and Conditions</a> and
                    <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
                </label>
                <span asp-validation-for="AgreeToTerms" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Register</button>
        </form>

        <p class="mt-3">
            Already have an account? <a href="/Account/LogIn">Log In</a>
        </p>
    }
</div>