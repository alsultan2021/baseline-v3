@model Baseline.Account.RCL.Features.ForgotPassword.ForgottenPasswordResetViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="password-reset-container">
    <h1>Reset Password</h1>
    
    @if (Model?.Succeeded == true)
    {
        <div class="alert alert-success">
            <p>Your password has been reset successfully.</p>
            <a href="@Model.LoginUrl" class="btn btn-primary">Log In</a>
        </div>
    }
    else
    {
        @if (Model?.ResultIdentity?.Errors.Any() == true)
        {
            <div class="alert alert-danger">
                <ul>
                    @foreach (var error in Model.ResultIdentity.Errors)
                    {
                        <li>@error.Description</li>
                    }
                </ul>
            </div>
        }
        
        <form method="post" asp-controller="ForgottenPasswordReset" asp-action="ForgottenPasswordReset">
            @Html.AntiForgeryToken()
            
            <input type="hidden" asp-for="UserID" />
            <input type="hidden" asp-for="Token" />
            
            <div class="form-group">
                <label asp-for="Password">New Password</label>
                <input asp-for="Password" type="password" class="form-control" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="PasswordConfirm">Confirm Password</label>
                <input asp-for="PasswordConfirm" type="password" class="form-control" required />
                <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-primary">Reset Password</button>
        </form>
    }
</div>
