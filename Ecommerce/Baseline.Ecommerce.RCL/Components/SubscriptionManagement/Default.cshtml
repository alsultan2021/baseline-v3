@model Baseline.Ecommerce.Components.SubscriptionManagementViewModel

<div class="subscription-management">
    <h2 class="h4 mb-4">Email Subscriptions</h2>

    @if (Model.Subscriptions.Count == 0)
    {
        <div class="alert alert-info">
            <i class="feather icon-feather-info me-2" aria-hidden="true"></i>
            No newsletters are currently available.
        </div>
    }
    else
    {
        <form asp-controller="Subscription" asp-action="UpdateSubscriptions" method="post">
            <input type="hidden" name="email" value="@Model.Email" />

            <div class="list-group mb-4">
                @foreach (var subscription in Model.Subscriptions)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="flex-grow-1">
                                <div class="form-check">
                                    <input type="checkbox" 
                                           class="form-check-input" 
                                           id="sub-@subscription.NewsletterName" 
                                           name="subscriptions"
                                           value="@subscription.NewsletterName"
                                           checked />
                                    <label class="form-check-label fw-medium" for="sub-@subscription.NewsletterName">
                                        @subscription.NewsletterDisplayName
                                    </label>
                                </div>
                            </div>
                            @if (subscription.SubscribedOn != default)
                            {
                                <small class="text-muted">
                                    Subscribed @subscription.SubscribedOn.ToString("MMM d, yyyy")
                                </small>
                            }
                        </div>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="feather icon-feather-save me-2" aria-hidden="true"></i>
                Save Preferences
            </button>
        </form>
    }
</div>
