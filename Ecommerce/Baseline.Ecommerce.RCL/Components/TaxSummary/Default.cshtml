@model Baseline.Ecommerce.Components.TaxSummaryComponentViewModel

@{
    var containerClass = "tax-summary";
    if (!string.IsNullOrEmpty(Model.CssClass))
    {
        containerClass += $" {Model.CssClass}";
    }
}

<div class="@containerClass">
    @if (Model.ShowDetails && Model.HasMultipleTaxes)
    {
        <!-- Multi-jurisdiction tax breakdown -->
        <div class="tax-breakdown">
            <h4 class="tax-breakdown-title">@Model.TaxLabel Breakdown</h4>
            <ul class="tax-line-items">
                @foreach (var item in Model.LineItems)
                {
                    <li class="tax-line-item">
                        <span class="tax-line-name">@item.Name</span>
                        <span class="tax-line-rate">(@item.FormattedRate)</span>
                        <span class="tax-line-amount">@item.Amount.ToString("C")</span>
                    </li>
                }
            </ul>
            <div class="tax-total">
                <span class="tax-total-label">Total @Model.TaxLabel</span>
                <span class="tax-total-amount">@Model.TaxAmount.ToString("C")</span>
            </div>
        </div>
    }
    else
    {
        <!-- Simple tax display -->
        <div class="tax-simple">
            <span class="tax-label">@Model.TaxLabel</span>
            @if (Model.ShowDetails && Model.TaxRate > 0)
            {
                <span class="tax-rate">(@Model.FormattedRate)</span>
            }
            <span class="tax-amount">@Model.TaxAmount.ToString("C")</span>
        </div>
    }

    @if (Model.TaxIncluded)
    {
        <div class="tax-included-notice">
            <small>@Model.TaxLabel included in prices</small>
        </div>
    }
</div>

<style>
    .tax-summary {
        margin: 0.5rem 0;
    }

    .tax-simple {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

    .tax-label {
        color: var(--text-muted, #6c757d);
    }

    .tax-rate {
        font-size: 0.875em;
        color: var(--text-muted, #6c757d);
    }

    .tax-amount {
        font-weight: 500;
    }

    .tax-breakdown {
        border: 1px solid var(--border-color, #dee2e6);
        border-radius: 0.375rem;
        padding: 1rem;
    }

    .tax-breakdown-title {
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .tax-line-items {
        list-style: none;
        padding: 0;
        margin: 0 0 0.75rem 0;
    }

    .tax-line-item {
        display: flex;
        justify-content: space-between;
        padding: 0.25rem 0;
        font-size: 0.875rem;
    }

    .tax-line-name {
        flex: 1;
    }

    .tax-line-rate {
        color: var(--text-muted, #6c757d);
        margin: 0 0.5rem;
    }

    .tax-line-amount {
        font-weight: 500;
    }

    .tax-total {
        display: flex;
        justify-content: space-between;
        border-top: 1px solid var(--border-color, #dee2e6);
        padding-top: 0.5rem;
        font-weight: 600;
    }

    .tax-included-notice {
        margin-top: 0.25rem;
        color: var(--text-muted, #6c757d);
    }
</style>