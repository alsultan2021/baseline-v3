@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; margin: 0; padding: 40px; background: #f8f9fa; }
        .error-container { max-width: 600px; margin: 0 auto; text-align: center; }
        .error-code { font-size: 120px; font-weight: bold; color: #dee2e6; margin: 0; }
        h1 { color: #212529; margin: 20px 0 10px; }
        p { color: #6c757d; margin: 10px 0 30px; }
        .btn { display: inline-block; padding: 12px 24px; background: #0d6efd; color: white; text-decoration: none; border-radius: 6px; margin: 5px; }
        .btn:hover { background: #0b5ed7; }
        .btn-secondary { background: #6c757d; }
        .btn-secondary:hover { background: #5c636a; }
    </style>
</head>
<body>
    <div class="error-container">
        <p class="error-code">403</p>
        <h1>Access Denied</h1>
        <p>You don't have permission to access this resource.</p>
        <a href="/" class="btn">Go to Homepage</a>
        <a href="/Account/LogIn" class="btn btn-secondary">Log In</a>
    </div>
</body>
</html>
