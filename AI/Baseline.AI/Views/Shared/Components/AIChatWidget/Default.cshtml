@model Baseline.AI.ViewComponents.AIChatWidgetViewModel

<link rel="stylesheet" href="~/_content/Baseline.AI/ai-chat-widget.css" />

<div class="ai-chat-widget" data-kb-id="@Model.KnowledgeBaseId" data-theme="@Model.Theme"
     data-position="@Model.Position" data-initial-expanded="@Model.InitialExpanded.ToString().ToLower()">

    <!-- Chat Toggle Button -->
    <button type="button" class="ai-chat-toggle" aria-label="Open chat">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
    </button>

    <!-- Chat Window -->
    <div class="ai-chat-window" style="display: none;">
        <!-- Header -->
        <div class="ai-chat-header">
            <h3 class="ai-chat-title">@Model.Title</h3>
            <button type="button" class="ai-chat-close" aria-label="Close chat">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        <!-- Messages -->
        <div class="ai-chat-messages" role="log" aria-live="polite">
            <div class="ai-chat-message ai-chat-message-bot">
                <div class="ai-chat-message-content">
                    @Model.WelcomeMessage
                </div>
            </div>
        </div>

        <!-- Suggested Questions -->
        @if (Model.StarterQuestions?.Count > 0)
        {
            <div class="ai-chat-suggestions" role="group" aria-label="Suggested questions">
                @foreach (var q in Model.StarterQuestions)
                {
                    <button type="button" class="ai-chat-suggestion" data-question="@q">@q</button>
                }
            </div>
        }

        <!-- Input -->
        <form class="ai-chat-input-form" autocomplete="off">
            <input type="text" class="ai-chat-input" placeholder="@Model.Placeholder" aria-label="Type your message"
                   maxlength="500" />
            <button type="submit" class="ai-chat-send" aria-label="Send message" disabled>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"></line>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>
            </button>
        </form>

        <!-- Loading -->
        <div class="ai-chat-loading" style="display: none;">
            <span class="ai-chat-loading-dot"></span>
            <span class="ai-chat-loading-dot"></span>
            <span class="ai-chat-loading-dot"></span>
        </div>
    </div>
</div>

<script src="~/_content/Baseline.AI/ai-chat-widget.js"></script>